#: ../ubiquity.templates:302001
msgid "After:"
msgstr "之後："

#. Type: text
#. Description
#: ../ubiquity.templates:303001
msgid "Encrypt the new ${RELEASE} installation for security"
msgstr "加密 ${RELEASE} 新安裝以保障安全性"

