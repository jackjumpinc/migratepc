#: ../ubiquity.templates:360001
msgid "Display recovery key:"
msgstr "Helyreállítási kulcs megjelenítése:"

#. Type: text
#. Description
#: ../ubiquity.templates:361001
msgid ""
"A recovery key is generated and will be temporarily saved on the live "
"system. You can select an alternate location. Save this file and keep it in "
"a safe place elsewhere before rebooting."
msgstr ""
"Egy helyreállítási kulcs lesz előállítva, amely átmenetileg az éles "
"rendszeren lesz elmentve. Kiválaszthat egy másik helyet is. Az újraindítás "
"előtt mentse el ezt a fájlt, és tartsa valamilyen más biztonságos helyen."

#. Type: text
#. Description
#: ../ubiquity.templates:362001
msgid "Location:"
msgstr "Hely:"

#. Type: text
#. Description
#: ../ubiquity.templates:363001
msgid "It is not recommended to store the key on a non removable device."
msgstr "Nem ajánlott a kulcsot egy nem cserélhető eszközön tartani."

