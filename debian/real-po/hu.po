msgstr "A hálózati beállítások másolása során hiba lépett fel."

#. Type: error
#. Description
#: ../ubiquity.templates:174001
msgid ""
"An error occurred while copying the network settings.  The installation will "
"continue, but the network configuration will have to be set up again in the "
"installed system."
msgstr ""
"A hálózati beállítások másolása meghiúsult. A telepítés folytatódik, azonban "
"elképzelhető, hogy a hálózati beállításait újra meg kell adnia a telepített "
"rendszernek."

#. Type: error
#. Description
#: ../ubiquity.templates:175001
msgid "Error copying bluetooth configuration"
msgstr "A bluetooth beállításainak másolása során hiba lépett fel"

#. Type: error
#. Description
#: ../ubiquity.templates:175001
msgid ""
"An error occurred while copying the bluetooth settings.  The installation "
"will continue, but the bluetooth configuration will have to be set up again "
"in the installed system."
msgstr ""
"A bluetooth beállításainak másolása meghiúsult. A telepítés folytatódik, "
"azonban elképzelhető, hogy a bluetooth beállításait újra meg kell adnia a "
"telepített rendszernek."

#. Type: error
